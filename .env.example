# База данных (обязательно). При P1008/Socket timeout уменьшите конкуренцию (очередь уже сериализует старт).
DATABASE_URL=file:./db/custom.db

# Папка для сохранения загруженных видео
DOWNLOAD_PATH=./downloads

# Папка с yt-dlp и ffmpeg (опционально, для портативной установки)
TOOLS_DIR=./data/tools

# Если при загрузке с YouTube ошибки "Failed to resolve i.ytimg.com / googlevideo.com"
# (getaddrinfo failed / Errno 11001 на Windows) — смените DNS на ПК на 8.8.8.8 / 8.8.4.4.
# Если "Read timed out" на NAS — задайте таймаут в секундах (например 60–120):
# YTDLP_SOCKET_TIMEOUT=120
# При Connect Timeout при загрузке превью (i.ytimg.com) — таймаут в мс (по умолчанию 30000, макс 120000):
# THUMBNAIL_FETCH_TIMEOUT_MS=60000
# Подробнее: .docs/DNS_AND_NETWORK.md

# Пути к утилитам (опционально, если не в PATH)
# FFMPEG_PATH=
# YTDLP_PATH=

# === Настройки по умолчанию ===

# Качество видео: best, 1080, 720, 480
DEFAULT_QUALITY=best

# Формат контейнера: mp4, mkv, webm
DEFAULT_FORMAT=mp4

# Дней истории при добавлении новой подписки
DEFAULT_SUBSCRIPTION_HISTORY_DAYS=30

# Интервал проверки подписок (минуты)
DEFAULT_CHECK_INTERVAL=60

# Автопроверка подписок по расписанию (1 — вкл, 0 — выкл)
SUBSCRIPTION_AUTO_CHECK_ENABLED=1
# Интервал пробуждения планировщика (мин). При активных загрузках проверка пропускается
SUBSCRIPTION_SCHEDULER_INTERVAL_MIN=5
# Максимум видео, которые смотрим при ручной/плановой проверке подписки
# (больше — медленнее; обычно хватает 30–80)
SUBSCRIPTION_CHECK_VIDEO_LIMIT=50

# Количество карточек в блоках «Последние скаченные» / «Последние просмотренные» (медиатека)
MEDIA_LIBRARY_RECENT_LIMIT=8

# Максимум одновременных загрузок в очереди
# (1 — безопасно; 2–3 быстрее, но больше нагрузка на сеть/диск/CPU)
QUEUE_MAX_CONCURRENT_DOWNLOADS=1

# Уровень журнала очереди загрузки и подписок (файл log/queue.log в папке yt-dlp): none, error, warn, info, debug
QUEUE_LOG_LEVEL=info

# ===== Auth (NextAuth) =====
# URL приложения:
# - в режиме разработки (npm run dev / npm run start) — фактический URL, по которому вы открываете UI
#   (обычно http://localhost:3000 или http://<IP-вашей-машины>:3000);
# - в Docker / на NAS — значение берётся из переменной окружения контейнера (docker-compose, UI NAS),
#   и должно строго совпадать с реальным URL (протокол, хост, порт), иначе авторизация (NextAuth) может не работать.
NEXTAUTH_URL=http://localhost:3000

# Базовый адрес сервера (для ссылок «Поделиться» и публичной страницы просмотра).
# В Docker / production обычно указывает на внешний публичный адрес (домен за обратным proxy),
# и может отличаться от NEXTAUTH_URL.
BASE_URL=http://localhost:3000

# Секрет для подписи JWT/сессий (любой длинный случайный).
# В production обязателен. Пример: openssl rand -base64 32
NEXTAUTH_SECRET=

# Пароль учётной записи admin при первом запуске (только для создания/обновления).
# В production задайте свой пароль и смените его после первого входа в Профиле.
# В development при отсутствии используется 'admin'.
# INITIAL_ADMIN_PASSWORD=

# OAuth (Google) — опционально
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
