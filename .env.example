# База данных (обязательно). При P1008/Socket timeout уменьшите конкуренцию (очередь уже сериализует старт).
DATABASE_URL=file:./db/custom.db

# Папка для сохранения загруженных видео
DOWNLOAD_PATH=./downloads

# Папка с yt-dlp и ffmpeg (опционально, для портативной установки)
TOOLS_DIR=./data/tools

# Если при загрузке с YouTube ошибки "Failed to resolve i.ytimg.com / googlevideo.com"
# (getaddrinfo failed / Errno 11001 на Windows) — смените DNS на ПК на 8.8.8.8 / 8.8.4.4.
# Если «Read timed out» / «Unable to download API page» от youtube.com (yt-dlp + проверка подписок) — задайте секунды (120–180 на медленном канале):
# YTDLP_SOCKET_TIMEOUT=120
# При Connect Timeout при загрузке превью (i.ytimg.com) — таймаут в мс (по умолчанию 30000, макс 120000):
# THUMBNAIL_FETCH_TIMEOUT_MS=60000
# Подробнее: .docs/DNS_AND_NETWORK.md

# Пути к утилитам (опционально, если не в PATH)
# FFMPEG_PATH=
# YTDLP_PATH=

# Извлечение аудио в AAC (меню «Скачать» → «Аудио»): битрейт для -b:a (96k, 128k или число 96 → 96k).
# Для админа то же можно задать в UI: Настройки → «Скачивание аудио (AAC)».
AUDIO_EXTRACT_AAC_BITRATE=96k
# Моно: 1 / true / yes / on — -ac 1 (меньше файл и чуть быстрее кодирование)
AUDIO_EXTRACT_AAC_MONO=0

# Сколько аудио может одновременно готовиться в браузере (разные карточки). 1 — по очереди, без лавины ffmpeg на сервере
# NEXT_PUBLIC_AUDIO_DOWNLOAD_MAX_CONCURRENT=1

# === Настройки по умолчанию ===

# Качество видео по умолчанию
# Допустимые значения (UI): best, 1080, 720, 480
DEFAULT_QUALITY=best

# Формат видео по умолчанию
# Допустимые значения (UI): mp4, mkv, webm
DEFAULT_FORMAT=mp4

# Дней истории при добавлении новой подписки
# Допустимые значения (UI): 7, 14, 30, 60, 90, 365, 730, 1095
DEFAULT_SUBSCRIPTION_HISTORY_DAYS=30

# Удалять видео подписки через N дней (0 — не удалять)
# Допустимые значения (UI): 0, 7, 14, 30, 60, 90, 365, 730, 1095
DEFAULT_SUBSCRIPTION_AUTO_DELETE_DAYS=30

# Интервал проверки подписок (минуты)
DEFAULT_CHECK_INTERVAL=60

# Автопроверка подписок по расписанию (1 — вкл, 0 — выкл)
SUBSCRIPTION_AUTO_CHECK_ENABLED=1
# Интервал пробуждения планировщика (мин). При активных загрузках проверка пропускается
SUBSCRIPTION_SCHEDULER_INTERVAL_MIN=5
# Максимум видео, которые смотрим при ручной/плановой проверке подписки
# (больше — медленнее; обычно хватает 30–80)
SUBSCRIPTION_CHECK_VIDEO_LIMIT=50

# Количество карточек в блоках «Последние скаченные» / «Последние просмотренные» (медиатека)
MEDIA_LIBRARY_RECENT_LIMIT=8

# Максимум одновременных загрузок в очереди
# (1 — безопасно; 2–3 быстрее, но больше нагрузка на сеть/диск/CPU)
QUEUE_MAX_CONCURRENT_DOWNLOADS=1

# Уровень журнала очереди загрузки, подписок и пользовательского Telegram-бота (файл log/queue.log рядом с yt-dlp, см. TOOLS_DIR): none, error, warn, info, debug
# При debug в тот же файл пишутся шаги AI-умного поиска (префикс [ai-smart-search-vN], N = версия алгоритма в ответе API).
# Сообщения бота имеют префикс telegram_user_bot.* (при none — в файл не пишутся).
QUEUE_LOG_LEVEL=debug

# Отладка Chromecast: 1 — логирование запросов к /api/stream в терминал (Docker logs)
CHROMECAST_DEBUG=1
# Отладка Chromecast в браузере: 1 — вывод в консоль DevTools (F12)
NEXT_PUBLIC_CHROMECAST_DEBUG=1

# ===== Auth (NextAuth) =====
# URL приложения:
# - в режиме разработки (npm run dev / npm run start) — фактический URL, по которому вы открываете UI
#   (обычно http://localhost:3000 или http://<IP-вашей-машины>:3000);
# - в Docker / на NAS — значение берётся из переменной окружения контейнера (docker-compose, UI NAS),
#   и должно строго совпадать с реальным URL (протокол, хост, порт), иначе авторизация (NextAuth) может не работать.
NEXTAUTH_URL=http://localhost:3000

# Базовый адрес сервера (для ссылок «Поделиться» и публичной страницы просмотра).
# В Docker / production обычно указывает на внешний публичный адрес (домен за обратным proxy),
# и может отличаться от NEXTAUTH_URL.
BASE_URL=http://localhost:3000

# Секрет для подписи JWT/сессий (любой длинный случайный).
# В production обязателен. Пример: openssl rand -base64 32
NEXTAUTH_SECRET=

# Пароль учётной записи admin при первом запуске (только для создания/обновления).
# В production задайте свой пароль и смените его после первого входа в Профиле.
# В development при отсутствии используется 'admin'.
# INITIAL_ADMIN_PASSWORD=

# OAuth (Google) — опционально
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Telegram — опционально
# Бот для уведомлений администратору об ошибках и т.п. (токен у @BotFather)
TELEGRAM_BOT_TOKEN=
# ID чата администратора (узнать через @userinfobot или после /start бота)
TELEGRAM_ADMIN_CHAT_ID=
# Отдельный бот для уведомлений пользователям о новых видео по подпискам (не смешивать с TELEGRAM_BOT_TOKEN).
# Пользователи указывают свой Chat ID в профиле и пишут /start этому боту.
TELEGRAM_USER_BOT_TOKEN=
# Входящие команды (/id, /start): webhook (по умолчанию) или polling — фоновый getUpdates без HTTPS webhook (если доставка webhook не работает).
# TELEGRAM_USER_BOT_UPDATES_MODE=polling
# Webhook для команд бота (/id, /start и далее): setWebhook из профиля или POST /api/telegram/user-bot-set-webhook.
# Если задан секрет, webhook URL = …/api/telegram/user-bot-hook/<секрет> (секрет в пути — не теряется, если прокси обрезает query).
# Старый путь …/user-bot-webhook и ?tgSt= по-прежнему поддерживается для обратной совместимости.
# TELEGRAM_USER_BOT_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET_hex64

# AI (умный поиск видео и др.; ключ не коммитьте)
# Провайдер: Perplexity (щедрее лимиты на платных планах, но sonar часто отвечает прозой вместо JSON) или Groq/OpenAI-совместимый
# (дешёвый inference, но бесплатный tier с жёстким TPM — уменьшайте AI_SEARCH_V1_RERANK_POOL при 429).
AI_BASE_URL=https://api.groq.com/openai/v1
AI_API_KEY=
AI_HTTP_TIMEOUT=30
# Общие значения по умолчанию для задач (если не заданы *_MODEL / *_TEMPERATURE / *_MAX_TOKENS ниже)
AI_MODEL=openai/gpt-oss-20b
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=2048
# Поиск видео по запросу (переопределяют AI_MODEL / AI_TEMPERATURE / AI_MAX_TOKENS для этой задачи)
# Для JSON-этапов (ключи + реранк) лучше модель с заполненным message.content и поддержкой json_object; sonar — задайте другую модель или другой BASE_URL.
# Пример возврата на Perplexity: AI_BASE_URL=https://api.perplexity.ai, AI_SEARCH_VIDEO_MODEL=sonar или sonar-pro (см. документацию Perplexity).
AI_SEARCH_VIDEO_MODEL=
# Отдельные модели для этапов умного поиска (пусто = как AI_SEARCH_VIDEO_MODEL). Из доступного набора Groq:
# этап 1 — qwen/qwen3-32b (компактный JSON ключей; gpt-oss-20b часто уходит в reasoning без JSON).
# этап 3 — llama-3.3-70b-versatile (ранжирование пула). Альтернатива этап 1: openai/gpt-oss-120b; этап 3: qwen/qwen3-32b при нехватке 70B.
# Не использовать для поиска: meta-llama/llama-prompt-guard-2-* (классификаторы промптов, не общий chat).
# Если реранк с JSON даёт 400 (json_validate_failed) — AI_SEARCH_RERANK_RESPONSE_JSON=0.
AI_SEARCH_KEYWORDS_MODEL=qwen/qwen3-32b
AI_SEARCH_RERANK_MODEL=llama-3.3-70b-versatile
AI_SEARCH_VIDEO_TEMPERATURE=0.3
AI_SEARCH_VIDEO_MAX_TOKENS=2048
# max_tokens только для этапа ключевых слов (модели с reasoning нуждаются в большем лимите, иначе JSON обрезается)
AI_SEARCH_KEYWORDS_MAX_TOKENS=2048
# 1 — response_format json_object (OpenAI-совместимые API). На Groq с gpt-oss и др. обычно стоит 1, иначе ответ часто остаётся прозой/reasoning без JSON.
# Пусто/0 — выкл. Если POST chat/completions вернёт HTTP 400 из‑за response_format — выкл. здесь и ниже или смените модель (Ollama, часть Perplexity).
AI_SEARCH_KEYWORDS_RESPONSE_JSON=1
# Реранк: как KEYWORDS, если пусто; 0 — явно выкл. только для этапа 3 (если этап 1 ок, а реранк с JSON даёт 400).
AI_SEARCH_RERANK_RESPONSE_JSON=1
# max_tokens ответа реранга (список id + reasoning); не задано — max(1536, min(4096, AI_SEARCH_VIDEO_MAX_TOKENS))
AI_SEARCH_RERANK_MAX_TOKENS=2048
# Длины полей в JSON этапа реранга (усечение сниппетов; при жёстком TPM уменьшайте).
AI_SEARCH_RERANK_TITLE_CHARS=150
AI_SEARCH_RERANK_DESCRIPTION_CHARS=300
AI_SEARCH_RERANK_CHANNEL_CHARS=60
# (Устарело для пайплайна v1) Раньше: кандидаты по дате для одношагового AI-поиска
# AI_SEARCH_VIDEO_CANDIDATE_LIMIT=200
# AI-поиск (умный): при >5 совпадений — сколько первых (по дате) отдать на реранк LLM (меньше = меньше токенов на запрос, ниже риск TPM 429)
AI_SEARCH_V1_RERANK_POOL=40
# Максимум id в итоговой выдаче умного поиска (пагинация клиентом через ids в API)
AI_SEARCH_SMART_RESULT_CAP=24
# Дополнять после реранка LLM выдачу id из пула этапа 2 (порядок по дате) до SMART_RESULT_CAP. 1 — да (по умолчанию); 0 — только порядок LLM, без добора.
AI_SEARCH_SMART_APPEND_KEYWORD_POOL=1